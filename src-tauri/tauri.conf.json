{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "clockface",
  "version": "0.1.0",
  "identifier": "com.admin.clockface",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Clockface",
        "width": 240,
        "height": 240,
        "minWidth": 100,
        "minHeight": 100,
        "resizable": true,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "shadow": false,
        "url": "http://localhost:3030"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
